{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://regaudit-fhe.vaultbytes.com/schemas/v1/drift.input.json",
  "title": "Drift-detection audit input",
  "type": "object",
  "additionalProperties": false,
  "required": ["p", "q"],
  "properties": {
    "p": {"type": "array", "minItems": 1, "items": {"type": "number", "minimum": 0}},
    "q": {"type": "array", "minItems": 1, "items": {"type": "number", "minimum": 0}},
    "drift_threshold": {
      "type": "number",
      "minimum": 0,
      "default": 0.005
    }
  }
}
